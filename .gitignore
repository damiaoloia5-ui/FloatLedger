# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Build artifacts
build/
dist/
output/
*.spec.bak

# Release installers — do NOT store large binaries in Git.
# Upload them to GitHub Releases instead:
#   https://docs.github.com/en/repositories/releasing-projects-on-github
releases/*.exe

# Claude Code local session data
.claude/

# Serena MCP cache
.serena/

# Local app data and secrets
snapshot.json
**/snapshot.json
.env
.env.*
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer

# Logs and local diagnostics
*.log
logs/
*.tmp
*.temp

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
Desktop.ini
